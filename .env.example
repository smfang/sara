# Copy to .env and fill in values (never commit .env — it is gitignored).
#   cp .env.example .env
#
# Loaded automatically by src/config.py (pydantic-settings) and docker-compose `env_file`.

# -----------------------------------------------------------------------------
# LLM — pick one provider (default: kimi / Moonshot)
# -----------------------------------------------------------------------------
MODEL_API=kimi
MODEL_NAME=kimi-k2

# Primary key used by Config + CLI (--model-api-key). Works for the selected MODEL_API.
MODEL_API_KEY=

# Provider-specific keys (agents read these directly; main.py maps MODEL_API_KEY into them)
MOONSHOT_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ZHIPU_API_KEY=
# DEEPSEEK_API_KEY=

# Custom / OpenAPI-compatible endpoint (MODEL_API=openapi)
# MODEL_ENDPOINT=https://api.example.com/v1

# -----------------------------------------------------------------------------
# Local development
# -----------------------------------------------------------------------------
ARENA_DEV_MODE=true
SARA_DEV_MODE=true
SARA_TEST_MODE=true
SARA_API_KEY=
SARA_ADMIN_KEY=
SARABOX_API_KEY=dev-key
# SARABOX_ALLOWED_ORIGINS=http://localhost:8080

# -----------------------------------------------------------------------------
# ClickHouse (optional — in-memory fallback when unavailable in dev)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=default

# -----------------------------------------------------------------------------
# Arena server
# -----------------------------------------------------------------------------
ARENA_HOST=0.0.0.0
ARENA_PORT=8080
# ARENA_WALLET=arena.sandbox.eth
# MIN_PAYOUT_USDC=1.0

# -----------------------------------------------------------------------------
# x402 payments (optional — dev wallet used when empty in dev mode)
# -----------------------------------------------------------------------------
# X402_WALLET_PRIVATE_KEY=
# X402_WALLET_ADDRESS=
# X402_CHAIN=base
# X402_FACILITATOR_URL=
# X402_MAX_AUTO_PAY=1.0
# X402_SPENDING_LIMIT=100.0

# -----------------------------------------------------------------------------
# Osprey rule engine (Kafka)
# -----------------------------------------------------------------------------
# OSPREY_ENABLED=true
# OSPREY_KAFKA_SERVERS=localhost:9092
# OSPREY_INPUT_TOPIC=sara.events.input
# OSPREY_OUTPUT_TOPIC=sara.events.output

# Legacy / external Osprey worker URLs (if using separate Osprey deployment)
# OSPREY_BASE_URL=http://localhost:5004
# OSPREY_REPO_URL=https://github.com/roostorg/osprey
# OSPREY_RULESET_URL=https://github.com/your-org/your-ruleset

# -----------------------------------------------------------------------------
# UI / portal
# -----------------------------------------------------------------------------
# PHOEBE_AGENT_WALLET=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# SHADOW_MODE=false

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# DISCORD_TOKEN=
# TEE_TRAINING_ENCLAVE_URL=
# GLOBAL_MODEL_ENDPOINT=
# TEE_AGGREGATOR_ENDPOINT=
